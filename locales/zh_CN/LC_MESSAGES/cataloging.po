#: ../../source/cataloging.rst:1321
msgid "611"
msgstr ""

#: ../../source/cataloging.rst:1321
msgid "SUBJECT ADDED--MEETING"
msgstr ""

#: ../../source/cataloging.rst:1321
msgid "Authorized form of meeting names for meetings discussed in the work"
msgstr ""

#: ../../source/cataloging.rst:1323
msgid "630"
msgstr ""

#: ../../source/cataloging.rst:1323
msgid "SUBJECT ADDED--UNIFORM TITLE"
msgstr ""

#: ../../source/cataloging.rst:1323
msgid "Authorized form of titles for other works discussed in the work"
msgstr ""

#: ../../source/cataloging.rst:1323
msgid "See Authorized headings sheet and AACR2. Set the first indicator to the number of non-filing characters (i.e. characters in an initial articles plus the space... for \"The \" set the first indicator to '4'). If you found the name in the LC authority file, set the second indicator to '0'. Otherwise set the second indicator to '4'."
msgstr ""

#: ../../source/cataloging.rst:1325
msgid "650"
msgstr ""

#: ../../source/cataloging.rst:1325
msgid "SUBJECT ADDED--TOPICAL"
msgstr ""

#: ../../source/cataloging.rst:1325
msgid "Library of Congress Subject Heading terms describing the subject of the work"
msgstr ""

#: ../../source/cataloging.rst:1325 ../../source/cataloging.rst:1327
msgid "See Authorized headings sheet and AACR2. If you found the name in the LC authority file, set the second indicator to '0'. Otherwise set the second indicator to '4'."
msgstr ""

#: ../../source/cataloging.rst:1327
msgid "651"
msgstr ""

#: ../../source/cataloging.rst:1327
msgid "SUBJECT ADDED--GEOGRAPHICAL"
msgstr ""

#: ../../source/cataloging.rst:1327
msgid "Library of Congress Subject Heading geographical terms describing the subject of the work"
msgstr ""

#: ../../source/cataloging.rst:1329
msgid "655"
msgstr ""

#: ../../source/cataloging.rst:1329
msgid "INDEX TERM--GENRE/FORM"
msgstr ""

#: ../../source/cataloging.rst:1329
msgid "Describes what an item is as opposed to what the item is about."
msgstr ""

#: ../../source/cataloging.rst:1329
msgid "Generally used only for auction catalogs, which should have the genre heading \"Auction catalogs.\" (make sure to find the authorized heading!) If you found the name in the LC authority file, set the second indicator to '0'. If you are using a term from a specific thesaurus, set the second indicator to '7' and put the code for the thesaurus in subfield '2'. Otherwise set the second indicator to '4'."
