#: ../../source/cataloging.rst:1337
msgid "710"
msgstr ""

#: ../../source/cataloging.rst:1337
msgid "ADDED ENTRY--CORPORATE"
msgstr ""

#: ../../source/cataloging.rst:1337
msgid "Used for corporate bodies related to the production of the work (e.g. publishers)."
msgstr ""

#: ../../source/cataloging.rst:1339
msgid "711"
msgstr ""

#: ../../source/cataloging.rst:1339
msgid "ADDED ENTRY--MEETING"
msgstr ""

#: ../../source/cataloging.rst:1339
msgid "Used for meetings related to the production of the work (e.g. symposia that contributed to the work)."
