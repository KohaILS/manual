#: ../../source/cataloging.rst:1341
msgid "730"
msgstr ""

#: ../../source/cataloging.rst:1341
msgid "ADDED ENTRY--UNIFORM TITLE"
msgstr ""

#: ../../source/cataloging.rst:1341
msgid "Used for uniform titles related to the production of the work (e.g. a work that inspired the present work)"
msgstr ""

#: ../../source/cataloging.rst:1341
msgid "See Authorized headings sheet and AACR2. Set the first indicator to the number of non-filing characters (i.e. characters in an initial articles plus the space... for \"The \" set the first indicator to '4')."
msgstr ""

#: ../../source/cataloging.rst:1343
msgid "773"
msgstr ""

#: ../../source/cataloging.rst:1343
msgid "HOST ITEM ENTRY"
msgstr ""

#: ../../source/cataloging.rst:1343
msgid "Describes the larger bibliographic unit that contains the work (e.g. book or journal containing the article being described in the current record)"
msgstr ""

#: ../../source/cataloging.rst:1343
msgid "If the host publication is author main entry, enter the authorized form of the author's name in subfield 'a'. Put the title in subfield 't'. If the host publication is an independent work, put publication information in subfield 'd'. When available, ISSN and ISBN should always be used in, in subfields 'x' and 'z' respectively. Relationship information (e.g. volume number, page number, etc.) goes in subfield 'g'. Subfield 'q' contains an encoded representation of the location of the item: volume, issue, and section numbers are separated by colons, and the first page is entered following a '<' at the end of the subfield. See ISBD punctuation sheet. Set the first indicator to '0'. If you want the label \"In:\" to be generated, leave the second indicator blank. If you want something else displayed before the 773 text, set the second indicator to '8' and add a subfield 'i' with the label you want at the beginning of the field (e.g. \"$iOffprint from:\")."
msgstr ""

#: ../../source/cataloging.rst:1345
msgid "830"
msgstr ""

#: ../../source/cataloging.rst:1345
msgid "SERIES ENTRY--UNIFORM TITLE"
msgstr ""

#: ../../source/cataloging.rst:1345
msgid "Authorized form of the series name transcribed in the 490 field. Often this will just be the same as the 490."
msgstr ""

#: ../../source/cataloging.rst:1345
msgid "See Authorized headings sheet and AACR2. Set the second indicator to the number of non-filing characters (i.e. characters in an initial articles plus the space... for \"The \" set the second indicator to '4')."
msgstr ""

#: ../../source/cataloging.rst:1347
msgid "852"
msgstr ""

#: ../../source/cataloging.rst:1347
msgid "LOCATION/CALL NUMBER"
msgstr ""

#: ../../source/cataloging.rst:1347
msgid "Provides the section name for pre-barcode books, pamphlets, and some articles and serials."
msgstr ""

#: ../../source/cataloging.rst:1347
msgid "Do not put anything in this field if you are cataloging a volume which gets only one record and a barcode. If the item does not get a barcode, or you are currently creating a record for an article in a volume, put the section in subfield 'a' (see ANS cataloging documentation), and the call number in subfield 'i'. Set the first indicator to '8'."
msgstr ""

#: ../../source/cataloging.rst:1349
