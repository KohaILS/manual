msgid "110"
msgstr ""

#: ../../source/cataloging.rst:1279
msgid "MAIN ENTRY--CORPORATE"
msgstr ""

#: ../../source/cataloging.rst:1279
msgid "Authorized form of the name of the main corporate author. Required for auction catalogs."
msgstr ""

#: ../../source/cataloging.rst:1279
msgid "Auction catalogs should use a 110 field rather than a 100 field. See Authorized headings sheet and AACR2. Set the first indicator to '2'."
msgstr ""

#: ../../source/cataloging.rst:1281
msgid "111"
msgstr ""

#: ../../source/cataloging.rst:1281
msgid "MAIN ENTRY--MEETING"
msgstr ""

#: ../../source/cataloging.rst:1281
msgid "Authorized form of the name of a meeting which acted as a main offer (e.g. conference proceedings)"
msgstr ""

#: ../../source/cataloging.rst:1281 ../../source/cataloging.rst:1337
#: ../../source/cataloging.rst:1339
msgid "See Authorized headings sheet and AACR2. Set the first indicator to '2'."
msgstr ""

#: ../../source/cataloging.rst:1283
msgid "245"
msgstr ""

#: ../../source/cataloging.rst:1283
msgid "TITLE STATEMENT"
msgstr ""

#: ../../source/cataloging.rst:1283
msgid "Transcription of the title statement from the title page (or chief source of information)"
msgstr ""

#: ../../source/cataloging.rst:1283
msgid "Enter the title in subfield 'a', the subtitle in subfield 'b', and the statement of responsibility in subfield 'c'. If you are creating a record for a single volume or part of a multi-part item, you should put the part number in subfield 'n' and the part title in subfield 'p.' For auction catalogs, the date (in 'MM/DD/YYYY' format) should be listed in square brackets in subfield 'f'. See ISBD punctuation sheet. Set the first indicator to '0' if there is no author, otherwise set it to '1'. Set the second indicator to the number of non-filing characters (i.e. characters in an initial articles plus the space... for \"The \" set the second indicator to '4')."
msgstr ""

#: ../../source/cataloging.rst:1285
msgid "246"
msgstr ""

#: ../../source/cataloging.rst:1285
msgid "VARYING FORM OF TITLE"
msgstr ""

#: ../../source/cataloging.rst:1285
msgid "Alternate form of title for searching and filing purposes"
msgstr ""

#: ../../source/cataloging.rst:1285
msgid "If the patron might look for the work under a different title, enter it here. Do not include initial articles. The first indicator should be '3', unless the title is merely a variant spelling, in which case the first indicator should be '1'."
msgstr ""

#: ../../source/cataloging.rst:1287
msgid "250"
msgstr ""

#: ../../source/cataloging.rst:1287
msgid "EDITION STATEMENT"
msgstr ""

#: ../../source/cataloging.rst:1287
msgid "Transcription of the edition statement from the title page (or chief source of information)"
msgstr ""

#: ../../source/cataloging.rst:1287
msgid "Transcribe the edition statement exactly as it appears on the title-page. You may abbreviate if the edition statement is very long."
msgstr ""

#: ../../source/cataloging.rst:1289
msgid "260"
msgstr ""

#: ../../source/cataloging.rst:1289
msgid "PUBLICATION (IMPRINT)"
msgstr ""

#: ../../source/cataloging.rst:1289
msgid "Publication information."
msgstr ""

#: ../../source/cataloging.rst:1289
msgid "Put the location of publication in subfield 'a', the publisher in subfield 'b', and the year (or probable year) in subfield 'c'. See ISBD punctuation sheet."
msgstr ""

#: ../../source/cataloging.rst:1291
msgid "264"
msgstr ""

#: ../../source/cataloging.rst:1291
msgid "PRODUCTION, PUBLICATION ETC."
