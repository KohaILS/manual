#: ../../source/cataloging.rst:1317
msgid "600"
msgstr ""

#: ../../source/cataloging.rst:1317
msgid "SUBJECT ADDED--PERSONAL"
msgstr ""

#: ../../source/cataloging.rst:1317
msgid "Authorized form of personal names for people discussed in the work"
msgstr ""

#: ../../source/cataloging.rst:1317
msgid "See Authorized headings sheet and AACR2. The first indicator should generally be a '1', to indicate that the entry is surname first. If the name consists only of a forename, however, the first indicator should be '0'. If you found the name in the LC authority file, set the second indicator to '0'. Otherwise set the second indicator to '4'."
