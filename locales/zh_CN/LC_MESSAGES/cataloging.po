msgstr ""

#: ../../source/cataloging.rst:1319 ../../source/cataloging.rst:1321
msgid "See Authorized headings sheet and AACR2. Set the first indicator to '2'. If you found the name in the LC authority file, set the second indicator to '0'. Otherwise set the second indicator to '4'."
