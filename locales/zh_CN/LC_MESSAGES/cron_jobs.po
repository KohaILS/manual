#: ../../source/cron_jobs.rst:443
msgid "This script replaces the j2a.pl script."
msgstr ""

#: ../../source/cron_jobs.rst:447
msgid "**DESCRIPTION**"
msgstr ""

#: ../../source/cron_jobs.rst:449
msgid "This script is designed to update patrons from one category to another using the criteria specified using command line arguments."
msgstr ""

#: ../../source/cron_jobs.rst:454
msgid "--too\\_old Update, if patron is over the upper age limit of their current :ref:`patron category <patron-categories-label>`."
msgstr ""

#: ../../source/cron_jobs.rst:458
msgid "--too\\_young Update, if patron is below the minimum age limit of their :ref:`patron category <patron-categories-label>`."
msgstr ""

#: ../../source/cron_jobs.rst:462
msgid "--fo=X|--fineover=X Update, if the total fine amount on the patron account is over X."
msgstr ""

#: ../../source/cron_jobs.rst:465
msgid "--fu=X|--fineunder=X Update, if the total fine amount on the patron account is below X."
msgstr ""

#: ../../source/cron_jobs.rst:468
msgid "--rb=date|regbefore=date Update, if the registration date of the patron is before the given date."
msgstr ""

#: ../../source/cron_jobs.rst:471
msgid "--ra=date|regafter=date Update, if the registration date of the patron is after the given date."
msgstr ""

#: ../../source/cron_jobs.rst:474
msgid "-d --field name=value Update, if the given condition is met. <name> has to be replaced by a column name of the borrowers table. The condition is met, if the the content of the field equals <value>."
msgstr ""

#: ../../source/cron_jobs.rst:478
msgid "--where <conditions> Update, if the SQL <where> clause is met."
msgstr ""

#: ../../source/cron_jobs.rst:481
msgid "-v|--verbose Verbose mode: Without this flag only fatal errors are reported."
msgstr ""

#: ../../source/cron_jobs.rst:484
msgid "-c|--confirm Commits the changes to the database. No changes will be made unless this argument is added to the command."
msgstr ""

#: ../../source/cron_jobs.rst:488
msgid "-b|--branch <branchcode> Update, if the home branch of the patron matches the <branchcode> given."
msgstr ""

#: ../../source/cron_jobs.rst:491
msgid "-f|--form <categorycode> Update, if the patron currently has this patron category."
msgstr ""

#: ../../source/cron_jobs.rst:494
msgid "-t|--to <categorycode> Update the patrons matching the criteria to this patron category."
msgstr ""

#: ../../source/cron_jobs.rst:497
msgid "**USAGE EXAMPLES**"
msgstr ""

#: ../../source/cron_jobs.rst:499
msgid "\"update\\_patrons\\_category.pl\""
msgstr ""

